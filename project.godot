; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="安全部物语 SecurityDeptStory"
config/description="企业安全部门模拟经营游戏 - 开罗风格"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/core/game_state.gd"
EmployeeRoster="*res://scripts/core/employee_roster.gd"
IncidentQueue="*res://scripts/core/incident_queue.gd"
AchievementMgr="*res://scripts/core/achievement_mgr.gd"
AwardMgr="*res://scripts/core/award_mgr.gd"
SaveMgr="*res://scripts/core/save_mgr.gd"
NGPlusMgr="*res://scripts/core/ng_plus_mgr.gd"
CEOMgr="*res://scripts/core/ceo_mgr.gd"
ConnectionMgr="*res://scripts/core/connection_mgr.gd"
ClientMgr="*res://scripts/core/client_mgr.gd"
ResearchMgr="*res://scripts/core/research_mgr.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=0
window/size/resizable=true
window/size/borderless=false
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[gui]

theme/custom="res://themes/main_theme.tres"
theme/default_font_multichannel_signed_distance_field=true

[rendering]

environment/defaults/default_clear_color=Color(0.13, 0.16, 0.22, 1)
